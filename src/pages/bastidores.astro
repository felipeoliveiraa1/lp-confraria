<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-600.woff2" />
<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-400.woff2" />

<style is:inline>
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:400;font-display:swap;src:url('/assets/InstrumentSans-400.woff2') format('woff2')}
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:500;font-display:swap;src:url('/assets/InstrumentSans-500.woff2') format('woff2')}
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:600;font-display:swap;src:url('/assets/InstrumentSans-600.woff2') format('woff2')}
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:700;font-display:swap;src:url('/assets/InstrumentSans-700.woff2') format('woff2')}

  :root{
    /* paleta preto + verde (acompanha a página original) sobre papel claro */
    --paper:#f7faf6; --paper-2:#edf3ea; --card:#fcfefb;
    --ink:#111a12; --sub:#4d5b4f; --faint:#7e8c80;
    --gold:#178a3a; --gold-soft:#22c55e; --gold-wash:rgba(34,197,94,.1);
    --navy:#0a140c; --navy-2:#152619;
    --line:#dfe8dc; --line-2:#c9dac6;
    --serif:'Iowan Old Style','Palatino Linotype','Book Antiqua',Palatino,Georgia,'Times New Roman',serif;
    --sans:'Instrument Sans',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;
    --maxw:1040px; --narrow:680px; --r:16px;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;scroll-padding-top:24px}
  body{background:var(--paper);color:var(--ink);font-family:var(--sans);font-size:17px;line-height:1.7;
    overflow-x:hidden;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  img{max-width:100%;height:auto;display:block}
  a{color:inherit;text-decoration:none}
  button{font-family:inherit}

  .wrap{width:100%;max-width:var(--maxw);margin:0 auto;padding:0 22px}
  .narrow{max-width:var(--narrow);margin-inline:auto}
  .section{padding:clamp(56px,9vw,104px) 0}
  .section--alt{background:var(--paper-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .center{text-align:center}

  .kicker{font-family:var(--sans);font-weight:600;font-size:12.5px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold)}
  .kicker::before,.kicker::after{content:'—';color:var(--line-2);margin:0 10px;font-weight:400}
  h1,h2,h3{font-family:var(--serif);font-weight:600;letter-spacing:-.01em;color:var(--ink)}
  .title-xl{font-size:clamp(30px,6.2vw,54px);line-height:1.14;margin-top:18px}
  .title-lg{font-size:clamp(25px,4.6vw,38px);line-height:1.2;margin-top:14px}
  .title-lg em,.title-xl em{font-style:italic;color:var(--gold)}
  .sub{color:var(--sub);font-size:clamp(16px,2.1vw,18.5px);margin-top:16px}
  .prose p{color:var(--sub);font-size:clamp(16px,2.1vw,18px);margin-top:18px;line-height:1.75}
  .prose p strong{color:var(--ink);font-weight:600}
  .rule{width:64px;height:2px;background:var(--gold);margin:26px auto 0;border-radius:2px}

  /* splits editoriais (texto + foto) */
  .split{display:grid;grid-template-columns:1fr 1fr;gap:clamp(30px,5.5vw,60px);align-items:center;text-align:left}
  .split .kicker::before,.split .kicker::after{content:'';margin:0}
  .split .rule{margin-left:0}
  .photo{border-radius:18px;border:1px solid var(--line-2);box-shadow:0 22px 50px rgba(9,18,11,.14);overflow:hidden;background:var(--card)}
  .photo img{width:100%;height:100%;object-fit:cover}
  .photo--tall img{aspect-ratio:4/5}
  @media (max-width:820px){.split{grid-template-columns:1fr}.photo--tall img{aspect-ratio:4/3}}

  /* mini-cards com foto (trabalhando/guardando/gastando) */
  .trio{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:clamp(32px,5vw,44px)}
  .mini{background:var(--card);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;
    box-shadow:0 14px 34px rgba(9,18,11,.08);transition:transform .2s ease,box-shadow .2s}
  .mini:hover{transform:translateY(-4px);box-shadow:0 20px 44px rgba(9,18,11,.13)}
  .mini img{width:100%;aspect-ratio:16/10;object-fit:cover}
  .mini figcaption{padding:14px 16px 16px}
  .mini .mn{font-family:var(--serif);font-style:italic;color:var(--gold);font-size:15px}
  .mini p{color:var(--sub);font-size:14.5px;line-height:1.5;margin-top:4px}

  /* botão */
  .btn{display:inline-flex;align-items:center;justify-content:center;text-align:center;gap:10px;max-width:100%;
    background:var(--navy);color:#eefbf0;font-family:var(--sans);font-weight:600;border:0;cursor:pointer;
    font-size:clamp(15px,2.4vw,17.5px);letter-spacing:.02em;padding:17px clamp(22px,5vw,38px);border-radius:999px;
    box-shadow:0 14px 30px rgba(9,18,11,.22);transition:transform .18s ease,box-shadow .18s ease,background .18s;will-change:transform}
  .btn:hover{transform:translateY(-2px);background:var(--navy-2);box-shadow:0 18px 38px rgba(9,18,11,.3)}
  .btn .arr{font-family:var(--serif);font-style:italic;color:var(--gold-soft)}
  .btn--gold{background:linear-gradient(160deg,#2bd465,#17a94b);color:#fff;box-shadow:0 14px 32px rgba(34,197,94,.35)}
  .btn--gold:hover{background:linear-gradient(160deg,#35e072,#1cb954);box-shadow:0 18px 40px rgba(34,197,94,.45)}

  /* hero */
  .hero{padding:clamp(56px,9vw,96px) 0 clamp(48px,7vw,80px);text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'';position:absolute;inset:0;pointer-events:none;background:
    radial-gradient(720px 380px at 50% -8%, var(--gold-wash), transparent 70%)}
  .hero .wrap{position:relative}

  .hero .btn{margin-top:clamp(28px,4.5vw,38px)}

  /* ===== carrossel de capítulos ===== */
  .car{position:relative;margin-top:clamp(34px,5vw,48px)}
  .car-track{display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;
    scrollbar-width:none;-ms-overflow-style:none;padding:10px 4px 20px;scroll-behavior:smooth}
  .car-track::-webkit-scrollbar{display:none}
  .chap{flex:0 0 min(76%,300px);scroll-snap-align:center;position:relative;text-align:left;
    background:var(--card);border:1px solid var(--line-2);border-radius:18px;padding:26px 24px 28px;
    box-shadow:0 18px 42px rgba(9,18,11,.1);overflow:hidden}
  .chap::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,#2bd465,#17a94b)}
  .chap::after{content:'';position:absolute;right:-26px;bottom:-26px;width:88px;height:88px;border-radius:50%;
    border:1px solid var(--line);opacity:.8}
  .chap .cnum{font-family:var(--serif);font-style:italic;font-size:44px;line-height:1;color:var(--gold)}
  .chap .clabel{font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--faint);margin-top:6px}
  .chap p{color:var(--sub);font-size:15.5px;line-height:1.6;margin-top:14px}
  .chap p strong{color:var(--ink);font-weight:600}
  .car-btn{position:absolute;top:50%;transform:translateY(-50%);z-index:5;width:44px;height:44px;border-radius:50%;
    border:1px solid var(--line-2);background:var(--card);color:var(--gold);font-family:var(--serif);font-size:20px;
    cursor:pointer;box-shadow:0 10px 24px rgba(9,18,11,.16);transition:transform .15s,background .15s;display:flex;align-items:center;justify-content:center}
  .car-btn:hover{transform:translateY(-50%) scale(1.08);background:#fff}
  .car-btn--prev{left:-8px}
  .car-btn--next{right:-8px}
  .car-dots{display:flex;gap:8px;justify-content:center;margin-top:4px}
  .car-dots button{width:8px;height:8px;border-radius:50%;border:0;cursor:pointer;background:var(--line-2);transition:background .2s,transform .2s;padding:0}
  .car-dots button.on{background:var(--gold);transform:scale(1.25)}

  /* citação editorial — mescla com a página original (hero-bg preto + feixes verdes) */
  .quote{color:#f0f7ec;text-align:center;padding:clamp(56px,8vw,88px) 0;position:relative;overflow:hidden;
    background:linear-gradient(rgba(4,8,12,.62),rgba(2,5,8,.86)),url('/assets/hero-bg.webp') center/cover no-repeat #05080c;
    border-top:1px solid #0d1512;border-bottom:1px solid #0d1512}
  .quote::before{content:'“';position:absolute;top:-30px;left:50%;transform:translateX(-50%);
    font-family:var(--serif);font-size:280px;line-height:1;color:rgba(30,255,0,.1);pointer-events:none}
  .quote p{font-family:var(--serif);font-style:italic;font-size:clamp(21px,3.8vw,32px);line-height:1.4;max-width:24ch;margin:0 auto;position:relative;
    text-shadow:0 2px 18px rgba(0,0,0,.6)}
  .quote p em{color:#1eff00;font-style:italic}
  .quote .qsrc{font-family:var(--sans);font-size:12.5px;letter-spacing:.22em;text-transform:uppercase;color:rgba(243,240,230,.55);margin-top:18px;position:relative}

  /* para quem — cards com foto */
  .fits{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:clamp(32px,5vw,44px);text-align:left}
  .fit{background:var(--card);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;
    box-shadow:0 14px 34px rgba(9,18,11,.08);transition:transform .2s ease,box-shadow .2s}
  .fit:hover{transform:translateY(-4px);box-shadow:0 20px 44px rgba(9,18,11,.13)}
  .fit img{width:100%;aspect-ratio:16/9;object-fit:cover}
  .fit .ft{display:flex;gap:12px;align-items:flex-start;padding:18px 20px 20px}
  .fit svg{flex:0 0 22px;width:22px;height:22px;margin-top:3px;stroke:var(--gold);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .fit p{color:var(--sub);font-size:15.5px;line-height:1.6;margin:0}
  .fit p strong{color:var(--ink);font-weight:600}

  /* leitura (bloco 5) */
  .devices{display:flex;gap:26px;margin-top:30px;color:var(--faint)}
  .devices .dv{display:flex;flex-direction:column;align-items:center;gap:8px;font-size:13px;letter-spacing:.06em;text-transform:uppercase}
  .devices svg{width:30px;height:30px;stroke:var(--gold);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}

  /* oferta */
  .offer-card{max-width:600px;margin:0 auto;background:var(--card);border:1px solid var(--line-2);border-radius:24px;
    padding:clamp(32px,6vw,52px) clamp(20px,5vw,48px);text-align:center;box-shadow:0 30px 70px rgba(9,18,11,.12)}
  .offer-list{list-style:none;margin:24px auto 0;max-width:420px;text-align:left}
  .offer-list li{display:flex;gap:12px;align-items:flex-start;color:var(--sub);font-size:16px;line-height:1.55;padding:9px 0;border-top:1px solid var(--line)}
  .offer-list li:first-child{border-top:0}
  .offer-list svg{flex:0 0 20px;width:20px;height:20px;margin-top:3px;stroke:var(--gold);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  /* bloco de preço (De / Por / ou / à vista) — painel dark no estilo da página original */
  .price-box{margin:28px auto 0;max-width:420px;border:1px solid rgba(34,197,94,.4);border-radius:18px;
    background:radial-gradient(280px 140px at 50% -30px, rgba(30,255,0,.14), transparent 70%),
      linear-gradient(180deg,#0c160e,#060d08);
    padding:26px 20px 28px;position:relative;overflow:hidden;box-shadow:0 24px 50px rgba(9,18,11,.28)}
  .price-from{color:#87a08c;font-size:16.5px}
  .price-from s{text-decoration:line-through}
  .price-main{margin-top:8px}
  .price-main .plabel{display:block;font-family:var(--sans);font-size:14px;letter-spacing:.14em;text-transform:uppercase;color:#9fb8a4;margin-bottom:2px}
  .price-main .pval{font-family:var(--sans);font-weight:700;color:#fff;font-size:clamp(34px,7vw,46px);
    line-height:1.08;letter-spacing:-.01em;white-space:nowrap;text-shadow:0 2px 16px rgba(30,255,0,.18)}
  .price-or{display:flex;align-items:center;gap:14px;margin:14px auto 10px;max-width:240px;color:#7d9483;
    font-family:var(--serif);font-style:italic;font-size:15px}
  .price-or::before,.price-or::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.14)}
  .price-cash{font-family:var(--sans);font-weight:700;color:#1eff00;font-size:clamp(22px,4.4vw,28px);letter-spacing:.01em}
  .offer-card .btn{margin-top:26px;width:100%}
  .seals{margin:20px auto 0;opacity:.85}

  /* ===== garantia — faixa dark mesclada da página original ===== */
  .guar{position:relative;overflow:hidden;color:#eef2ea;
    background:linear-gradient(rgba(3,7,4,.5),rgba(2,5,3,.78)),url('/assets/wpup_2026-01-bg-garantia.webp') center/cover no-repeat #04170c;
    border-top:1px solid #102015;border-bottom:1px solid #102015}
  .guar::before{content:'';position:absolute;inset:0;pointer-events:none;
    background:radial-gradient(720px 380px at 22% 50%, rgba(30,255,0,.1), transparent 70%)}
  .guar-grid{display:grid;grid-template-columns:minmax(0,340px) 1fr;gap:clamp(28px,5vw,56px);align-items:center;position:relative}
  .guar-badge{width:100%;max-width:340px;filter:drop-shadow(0 20px 40px rgba(0,0,0,.5))}
  .guar-body h2{color:#fff;font-size:clamp(26px,4.6vw,40px);line-height:1.15}
  .guar-body h2 em{font-style:italic;color:#1eff00}
  .guar-body p{color:#bcc9b8;font-size:clamp(15.5px,2.1vw,17.5px);line-height:1.7;margin-top:14px;max-width:52ch}
  .guar-body p strong{color:#fff}

  /* FAQ */
  .faq{max-width:640px;margin:clamp(32px,5vw,44px) auto 0;text-align:left}
  .faq details{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:0 22px;margin-top:12px}
  .faq summary{cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:14px;
    font-weight:600;font-size:16.5px;color:var(--ink);padding:18px 0}
  .faq summary::-webkit-details-marker{display:none}
  .faq summary::after{content:'+';font-family:var(--serif);font-size:22px;color:var(--gold);transition:transform .2s}
  .faq details[open] summary::after{transform:rotate(45deg)}
  .faq details p{color:var(--sub);font-size:15.5px;padding:0 0 18px;line-height:1.65}

  /* final */
  .final{background:var(--navy);color:#eef5ea;text-align:center}
  .final .kicker{color:var(--gold-soft)}
  .final .kicker::before,.final .kicker::after{color:rgba(255,255,255,.22)}
  .final h2{color:#f2fbef;font-size:clamp(26px,5.2vw,42px);line-height:1.2;margin-top:16px}
  .final .btn{margin-top:32px;background:linear-gradient(160deg,#2bd465,#17a94b);color:#fff;box-shadow:0 16px 40px rgba(0,0,0,.35)}
  .final .btn:hover{background:linear-gradient(160deg,#35e072,#1cb954)}

  .foot{padding:26px 0;text-align:center;color:var(--faint);font-size:12.5px;letter-spacing:.04em}

  /* reveal */
  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}

  @media (max-width:820px){
    .trio{grid-template-columns:1fr;max-width:420px;margin-left:auto;margin-right:auto}
    .mini img{aspect-ratio:16/8}
    .guar-grid{grid-template-columns:1fr;text-align:center}
    .guar-badge{margin:0 auto;max-width:260px}
    .guar-body p{margin-left:auto;margin-right:auto}
    .devices{justify-content:center}
  }
  @media (max-width:720px){
    .fits{grid-template-columns:1fr}
    .car-btn{display:none}
  }
  @media (prefers-reduced-motion:reduce){
    *{animation:none!important}
    .reveal{opacity:1;transform:none;transition:none}
    html{scroll-behavior:auto}
  }
</style>
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TXZ8KFR7" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<!-- ============ HERO ============ -->
<header class="hero">
  <div class="wrap">
    <p class="kicker">Os Bastidores da Moeda</p>
    <h1 class="title-xl narrow">O que há por trás do valor do dinheiro que você <em>usa todos os dias?</em></h1>

    <div><a class="btn" href="#oferta">QUERO CONHECER OS BASTIDORES <span class="arr">→</span></a></div>
  </div>
</header>

<!-- ============ BLOCO 2 ============ -->
<section class="section section--alt reveal">
  <div class="wrap">
    <div class="split">
      <div>
        <h2 class="title-lg">Você usa dinheiro todos os dias, mas você realmente sabe <em>por que ele vale o que vale?</em></h2>
        <div class="rule"></div>
        <div class="prose">
          <p>A maioria das pessoas passa a vida inteira trabalhando, guardando e gastando dinheiro sem nunca entender de onde vem o seu valor, e por que ele muda.</p>
          <p>Isso não é falta de inteligência. É porque essa história nunca foi contada de forma simples.</p>
          <p>Por trás de cada moeda, de cada crise cambial, de cada “dólar subiu” que você ouve no noticiário, existem decisões, disputas e bastidores que moldaram o mundo financeiro como ele é hoje, e que continuam se repetindo.</p>
        </div>
      </div>
      <div class="photo photo--tall"><img src={img.statement} alt="Extrato bancário no celular sobre contas e boletos" loading="lazy" decoding="async" /></div>
    </div>
    <div class="trio">
