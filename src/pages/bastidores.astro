<style is:inline>
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:400;font-display:swap;src:url('/assets/InstrumentSans-400.woff2') format('woff2')}
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:500;font-display:swap;src:url('/assets/InstrumentSans-500.woff2') format('woff2')}
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:600;font-display:swap;src:url('/assets/InstrumentSans-600.woff2') format('woff2')}
  @font-face{font-family:'Instrument Sans';font-style:normal;font-weight:700;font-display:swap;src:url('/assets/InstrumentSans-700.woff2') format('woff2')}

  :root{
    --paper:#faf8f3; --paper-2:#f3efe6; --card:#fffdf8;
    --ink:#1d2433; --sub:#535d70; --faint:#8a90a0;
    --gold:#b78a2e; --gold-soft:#caa14d; --gold-wash:rgba(183,138,46,.09);
    --navy:#1e2a4a; --navy-2:#27355c;
    --line:#e6dfd0; --line-2:#d8cfba;
    --serif:'Iowan Old Style','Palatino Linotype','Book Antiqua',Palatino,Georgia,'Times New Roman',serif;
    --sans:'Instrument Sans',system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;
    --maxw:1040px; --narrow:680px; --r:16px;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;scroll-padding-top:24px}
  body{background:var(--paper);color:var(--ink);font-family:var(--sans);font-size:17px;line-height:1.7;
    overflow-x:hidden;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  img{max-width:100%;height:auto;display:block}
  a{color:inherit;text-decoration:none}

  .wrap{width:100%;max-width:var(--maxw);margin:0 auto;padding:0 22px}
  .narrow{max-width:var(--narrow);margin-inline:auto}
  .section{padding:clamp(56px,9vw,104px) 0}
  .section--alt{background:var(--paper-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .center{text-align:center}

  .kicker{font-family:var(--sans);font-weight:600;font-size:12.5px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold)}
  .kicker::before,.kicker::after{content:'—';color:var(--line-2);margin:0 10px;font-weight:400}
  h1,h2{font-family:var(--serif);font-weight:600;letter-spacing:-.01em;color:var(--ink)}
  .title-xl{font-size:clamp(30px,6.2vw,54px);line-height:1.14;margin-top:18px}
  .title-lg{font-size:clamp(25px,4.6vw,38px);line-height:1.2;margin-top:14px}
  .title-lg em,.title-xl em{font-style:italic;color:var(--gold);}
  .sub{color:var(--sub);font-size:clamp(16px,2.1vw,18.5px);margin-top:16px}
  .prose p{color:var(--sub);font-size:clamp(16px,2.1vw,18px);margin-top:18px;line-height:1.75}
  .prose p strong{color:var(--ink);font-weight:600}
  .rule{width:64px;height:2px;background:var(--gold);margin:26px auto 0;border-radius:2px}

  /* splits editoriais (texto + foto) */
  .split{display:grid;grid-template-columns:1fr 1fr;gap:clamp(30px,5.5vw,60px);align-items:center;text-align:left}
  .split .kicker::before,.split .kicker::after{content:'';margin:0}
  .split .rule{margin-left:0}
  .photo{border-radius:18px;border:1px solid var(--line-2);box-shadow:0 22px 50px rgba(30,42,74,.14);overflow:hidden;background:var(--card)}
  .photo img{width:100%;height:100%;object-fit:cover}
  .photo--tall img{aspect-ratio:4/5}
  .banner{border-radius:18px;border:1px solid var(--line-2);box-shadow:0 20px 46px rgba(30,42,74,.12);overflow:hidden;margin-top:clamp(28px,5vw,40px)}
  .banner img{width:100%;aspect-ratio:21/10;object-fit:cover;object-position:center 30%}
  @media (max-width:820px){.split{grid-template-columns:1fr}.photo--tall img{aspect-ratio:4/3}}

  /* botão */
  .btn{display:inline-flex;align-items:center;justify-content:center;text-align:center;gap:10px;max-width:100%;
    background:var(--navy);color:#f6f1e5;font-family:var(--sans);font-weight:600;
    font-size:clamp(15px,2.4vw,17.5px);letter-spacing:.02em;padding:17px clamp(22px,5vw,38px);border-radius:999px;
    box-shadow:0 14px 30px rgba(30,42,74,.22);transition:transform .18s ease,box-shadow .18s ease,background .18s;will-change:transform}
  .btn:hover{transform:translateY(-2px);background:var(--navy-2);box-shadow:0 18px 38px rgba(30,42,74,.3)}
  .btn .arr{font-family:var(--serif);font-style:italic;color:var(--gold-soft)}
  .btn--gold{background:linear-gradient(160deg,#caa14d,#b78a2e);color:#241a05;box-shadow:0 14px 32px rgba(183,138,46,.35)}
  .btn--gold:hover{background:linear-gradient(160deg,#d3ab58,#c09134);box-shadow:0 18px 40px rgba(183,138,46,.45)}
  .btn-note{font-size:13px;color:var(--faint);margin-top:12px}

  /* hero */
  .hero{padding:clamp(56px,9vw,96px) 0 clamp(48px,7vw,80px);text-align:center;position:relative;overflow:hidden}
  .hero::before{content:'';position:absolute;inset:0;pointer-events:none;background:
    radial-gradient(720px 380px at 50% -8%, var(--gold-wash), transparent 70%)}
  .hero .wrap{position:relative}

  /* VSL facade (claro) */
  .vsl-slot{max-width:392px;margin:clamp(30px,5vw,44px) auto 0;position:relative;aspect-ratio:9/16;border-radius:18px;
    overflow:hidden;background:var(--navy);cursor:pointer;
    box-shadow:0 24px 60px rgba(30,42,74,.28),0 0 0 1px var(--line-2),0 0 0 7px var(--card),0 0 0 8px var(--line)}
  .vsl__poster{width:100%;height:100%;object-fit:cover;display:block}
  .vsl__cta{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;border:0;cursor:pointer;
    background:radial-gradient(circle,rgba(10,14,26,.05),rgba(10,14,26,.5))}
  .vsl__cta-box{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;
    width:54%;max-width:206px;aspect-ratio:1;padding:8%;border-radius:18px;
    background:linear-gradient(165deg,#26345c,#1a2340);box-shadow:0 14px 38px rgba(0,0,0,.4),inset 0 0 0 1px rgba(202,161,77,.5);
    transform:translateZ(0) scale(1);will-change:transform;transition:transform .15s ease;animation:vslPulse 2.1s ease-in-out infinite}
  .vsl__cta-icon{width:34%;height:auto;display:block}
  .vsl__cta-txt{color:#f2ead6;font-family:var(--sans);font-weight:700;font-size:clamp(14px,4vw,19px);
    line-height:1.1;letter-spacing:.5px;text-align:center;text-transform:uppercase}
  .vsl__cta:hover .vsl__cta-box{animation-play-state:paused;transform:translateZ(0) scale(1.05)}
  @keyframes vslPulse{0%,100%{transform:translateZ(0) scale(1)}50%{transform:translateZ(0) scale(1.06)}}
  .vsl-slot vturb-smartplayer{display:block;width:100%;height:100%}
  .hero .btn{margin-top:clamp(28px,4.5vw,38px)}

  /* capítulos (bloco 3) */
  .chapters{margin-top:clamp(34px,5vw,46px);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;background:var(--card)}
  .chapter{display:flex;gap:18px;align-items:flex-start;padding:22px 24px;border-top:1px solid var(--line)}
  .chapter:first-child{border-top:0}
  .chapter .num{font-family:var(--serif);font-style:italic;font-size:22px;color:var(--gold);min-width:38px;line-height:1.3}
  .chapter p{color:var(--sub);font-size:16.5px;line-height:1.65;margin:0}
  .chapter p strong{color:var(--ink);font-weight:600}

  /* para quem (bloco 4) */
  .fits{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:clamp(32px,5vw,44px);text-align:left}
  .fit{display:flex;gap:14px;align-items:flex-start;background:var(--card);border:1px solid var(--line);border-radius:var(--r);padding:20px 22px}
  .fit svg{flex:0 0 22px;width:22px;height:22px;margin-top:3px;stroke:var(--gold);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .fit p{color:var(--sub);font-size:16px;line-height:1.6;margin:0}

  /* leitura (bloco 5) */
  .devices{display:flex;gap:26px;justify-content:center;margin-top:30px;color:var(--faint)}
  .devices .dv{display:flex;flex-direction:column;align-items:center;gap:8px;font-size:13px;letter-spacing:.06em;text-transform:uppercase}
  .devices svg{width:30px;height:30px;stroke:var(--gold);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round}

  /* oferta (bloco 6) */
  .offer-card{max-width:560px;margin:0 auto;background:var(--card);border:1px solid var(--line-2);border-radius:22px;
    padding:clamp(32px,6vw,48px) clamp(20px,5vw,44px);text-align:center;
    box-shadow:0 30px 70px rgba(30,42,74,.12)}
  .offer-card .kicker::before,.offer-card .kicker::after{content:''}
  .offer-list{list-style:none;margin:26px auto 0;max-width:400px;text-align:left}
  .offer-list li{display:flex;gap:12px;align-items:flex-start;color:var(--sub);font-size:16px;line-height:1.55;padding:9px 0;border-top:1px solid var(--line)}
  .offer-list li:first-child{border-top:0}
  .offer-list svg{flex:0 0 20px;width:20px;height:20px;margin-top:3px;stroke:var(--gold);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .price-from{margin-top:28px;color:var(--faint);font-size:16px}
  .price-from s{text-decoration:line-through}
  .price{font-family:var(--serif);font-weight:600;color:var(--ink);font-size:clamp(30px,6vw,42px);line-height:1.15;margin-top:6px}
  .price small{display:block;font-family:var(--sans);font-weight:500;font-size:15px;color:var(--sub);margin-top:6px}
  .offer-card .btn{margin-top:26px;width:100%}
  .seals{margin:22px auto 0;opacity:.85}

  /* garantia (bloco 7) */
  .guarantee{display:flex;gap:26px;align-items:center;max-width:640px;margin:0 auto;background:var(--card);
    border:1px solid var(--line);border-radius:var(--r);padding:clamp(24px,5vw,36px)}
  .guarantee svg{flex:0 0 86px;width:86px;height:auto}
  .guarantee h2{font-size:clamp(20px,3.4vw,26px)}
  .guarantee p{color:var(--sub);font-size:16px;margin-top:8px}

  /* FAQ */
  .faq{max-width:640px;margin:clamp(32px,5vw,44px) auto 0;text-align:left}
  .faq details{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:0 22px;margin-top:12px}
  .faq summary{cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:14px;
    font-weight:600;font-size:16.5px;color:var(--ink);padding:18px 0}
  .faq summary::-webkit-details-marker{display:none}
  .faq summary::after{content:'+';font-family:var(--serif);font-size:22px;color:var(--gold);transition:transform .2s}
  .faq details[open] summary::after{transform:rotate(45deg)}
  .faq details p{color:var(--sub);font-size:15.5px;padding:0 0 18px;line-height:1.65}

  /* final */
  .final{background:var(--navy);color:#efe9da;text-align:center}
  .final .kicker{color:var(--gold-soft)}
  .final .kicker::before,.final .kicker::after{color:rgba(255,255,255,.22)}
  .final h2{color:#f7f2e6;font-size:clamp(26px,5.2vw,42px);line-height:1.2;margin-top:16px}
  .final .btn{margin-top:32px;background:linear-gradient(160deg,#caa14d,#b78a2e);color:#241a05;box-shadow:0 16px 40px rgba(0,0,0,.35)}
  .final .btn:hover{background:linear-gradient(160deg,#d3ab58,#c09134)}

  .foot{padding:26px 0;text-align:center;color:var(--faint);font-size:12.5px;letter-spacing:.04em}

  /* reveal */
  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}

  @media (max-width:720px){
    .fits{grid-template-columns:1fr}
    .guarantee{flex-direction:column;text-align:center}
  }
  @media (prefers-reduced-motion:reduce){
    *{animation:none!important}
    .reveal{opacity:1;transform:none;transition:none}
    html{scroll-behavior:auto}
  }
</style>
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TXZ8KFR7" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
