// "Os Bastidores da Moeda" — página de vendas (copy nova, tom claro/editorial).
// Self-contained: head + estilos próprios (NÃO usa o tema dark/neon da home).
// Mantém o tracking do funil (GTM + UTMify) por ser página de vendas da lp05.
// PLACEHOLDERS a trocar quando chegarem: checkout e parcela. (Página SEM VSL.)
const CHECKOUT = 'https://pay.kirvano.com/448e308a-ae99-4316-a0d7-3fdff88fd71e'; // TODO: checkout do ebook
const A = '/assets/';
const img = {
  statement: A + '1a4e3196f7247c55_IMG-AT-8_resultado1.webp',   // extrato no celular
  work: A + '036ac490246605f6_IMG-AT-2_resultado1-300x169.webp', // trabalhando (relógio/fábrica)
  save: A + '4d46614482b447c8_PQE-2_resultado12-300x150.webp',   // guardando (dinheiro na mesa)
  spend: A + '890fd3dff2bdf27a_IMG-AT-5_resultado1.webp',        // gastando (loja com o filho)
  reader: A + '05ee26ab29310d4b_PQE-3_resultado12-768x391.webp', // lendo no celular
  news: A + '40d52b57d7921fa7_IMG-AT-7_resultado1-300x169.webp', // confuso com o noticiário/contas
  desk: A + '1c147d119736ff85_IMG-AT-3_resultado1.webp',         // leitura na mesa (café)
  talk: A + 'eb2d974dbd294bee_IMG-AT-4_resultado1-300x169.webp', // conversa no escritório
  paris: A + 'passo4.webp',                                      // café da manhã (ler no seu tempo)
  selos: A + '898832b786512f24_SELOS-CHECKOUT.svg',
};
---
<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Os Bastidores da Moeda — a história que ninguém te ensinou sobre o dinheiro</title>
<meta name="description" content="Entenda o que há por trás do valor do dinheiro que você usa todos os dias. A história cambial mundial contada de forma simples, capítulo por capítulo." />
<meta name="robots" content="max-image-preview:large" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<!-- GTM como 1º script (mesmo container do funil) -->
