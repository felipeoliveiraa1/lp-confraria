<script is:inline>
  // reveal on scroll
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) { els.forEach(function (e) { e.classList.add('in'); }); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.06 });
    els.forEach(function (e) { io.observe(e); });
  })();

  // carrossel de capítulos: setas + dots + autoplay (pausa na interação)
  (function () {
    var track = document.getElementById('car-track'); if (!track) return;
    var cards = track.querySelectorAll('.chap');
    var dotsBox = document.getElementById('car-dots');
    var car = document.getElementById('car');
    var idx = 0, timer = null, paused = false;
    cards.forEach(function (_, i) {
      var d = document.createElement('button');
      d.type = 'button'; d.setAttribute('aria-label', 'Ir ao capítulo ' + (i + 1));
      d.addEventListener('click', function () { go(i); pause(); });
      dotsBox.appendChild(d);
    });
    var dots = dotsBox.querySelectorAll('button');
    function paint() { dots.forEach(function (d, i) { d.classList.toggle('on', i === idx); }); }
    function go(i) {
      idx = (i + cards.length) % cards.length;
      var c = cards[idx];
      track.scrollTo({ left: c.offsetLeft - (track.clientWidth - c.clientWidth) / 2, behavior: 'smooth' });
      paint();
    }
    car.querySelector('.car-btn--prev').addEventListener('click', function () { go(idx - 1); pause(); });
    car.querySelector('.car-btn--next').addEventListener('click', function () { go(idx + 1); pause(); });
    var st;
    track.addEventListener('scroll', function () {
      clearTimeout(st);
      st = setTimeout(function () {
        var mid = track.scrollLeft + track.clientWidth / 2, best = 0, bd = 1e9;
        cards.forEach(function (c, i) { var d = Math.abs(c.offsetLeft + c.clientWidth / 2 - mid); if (d < bd) { bd = d; best = i; } });
        idx = best; paint();
      }, 90);
    }, { passive: true });
    ['pointerdown', 'touchstart'].forEach(function (ev) { track.addEventListener(ev, pause, { passive: true }); });
    function pause() { paused = true; if (timer) { clearInterval(timer); timer = null; } }
    function auto() { if (!matchMedia('(prefers-reduced-motion: reduce)').matches) { timer = setInterval(function () { if (!paused) go(idx + 1); }, 4500); } }
    paint(); auto();
  })();
</script>
