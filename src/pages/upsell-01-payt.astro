---
import Funnel from '../layouts/Funnel.astro';
import Vsl from '../components/Vsl.astro';
import PaytButton from '../components/PaytButton.astro';
const PAYT = 'https://checkout.payt.com.br/multiple-oneclickbuyscript/LXGYD5.js';
---
<Funnel title="UPSELL 01 PAYT – A Sociedade Trader" poster="/assets/poster-upsell-01.webp">
  <!-- gate: esconde os botões até 5:00 após o play. Roda antes da pintura (sem flash);
       sem JS, nada é escondido (fallback). -->
  <script is:inline>try{if(!localStorage.getItem('al_up01_revealed'))document.documentElement.classList.add('gated')}catch(e){document.documentElement.classList.add('gated')}</script>
  <div class="scarcity">⚠️ IMPORTANTE: ESSA PÁGINA SAIRÁ DO AR EM <span id="cd">15:00</span></div>
  <main class="funnel">
    <div class="funnel-wrap">
      <h1 class="funnel-title">Sua compra ainda<br />não está completa…</h1>
      <ul class="steps-card">
        <li><span class="ic">✅</span> Passo 1: Sociedade do Trader</li>
        <li class="is-now"><span class="ic">⚙️</span> Passo 2: Configuração blindada</li>
        <li><span class="ic">⏳</span> Passo 3: Compra concluída!</li>
      </ul>
      <Vsl playerId="vid-6a35919a9a2aa374effcfe34" poster="/assets/poster-upsell-01.webp" />
      <div class="gate" id="up01-cta">
        <PaytButton object="LQO5E4-R2JNEO" label="QUERO GARANTIR MINHA CONFIGURAÇÃO BLINDADA." />
        <a class="decline" href="/downsell-payt/">NÃO QUERO ESSA OFERTA</a>
      </div>
    </div>
  </main>
  <script is:inline src={PAYT}></script>
  <!-- reveal timer: 5:00 após o play; uma vez revelado, persiste -->
  <script is:inline>
    (function () {
      var DELAY = 5 * 60 * 1000; // 5:00 = 300s
      var KEY = 'al_up01_revealed', scheduled = false;
      function reveal() {
        document.documentElement.classList.remove('gated');
        try { localStorage.setItem(KEY, '1'); } catch (e) {}
      }
      try { if (localStorage.getItem(KEY)) reveal(); } catch (e) {}
      window.__startVslTimer = function () {
        if (scheduled) return; scheduled = true;
        setTimeout(reveal, DELAY);
      };
    })();
  </script>
</Funnel>
