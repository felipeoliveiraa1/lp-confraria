---
import Funnel from '../layouts/Funnel.astro';
import Vsl from '../components/Vsl.astro';
---
<Funnel title="DOWNSELL PAYT – A Sociedade Trader" poster="/assets/poster-downsell-payt.webp">
  <!-- gate: esconde a oferta (copy + botões) até 1:30 após o play -->
  <script is:inline>try{if(!localStorage.getItem('al_dn01_revealed')&&!/[?&]preview/.test(location.search))document.documentElement.classList.add('gated')}catch(e){document.documentElement.classList.add('gated')}</script>
  <div class="scarcity">⚠️ IMPORTANTE: ESSA PÁGINA SAIRÁ DO AR EM <span id="cd">15:00</span></div>
  <main class="funnel">
    <div class="funnel-wrap">
      <h1 class="funnel-title">Eu não <span class="green">ACREDITO</span> que você vai obrigar a fazer isso</h1>
      <Vsl playerId="vid-6a3d1f804d2b4d3fb0012085" poster="/assets/poster-downsell-payt.webp" />
      <div class="gate" id="dn01-cta">
        <p class="funnel-sub">Essa será a sua última oportunidade de conseguir ter acesso a <strong>Configuração Blindada</strong>.</p>
        <p class="funnel-sub">Você já entende que acesso a Configuração Blindada te fará ter ainda mais resultado com menos esforço, né?</p>
        <p class="funnel-sub">Então, somente aqui e agora você poderá desbloquear o seu acesso com <strong>100 REAIS OFF</strong> de desconto tocando no botão abaixo…</p>
        <p class="funnel-price">De R$697 por <span class="green">R$597</span>.<small>Você também pode parcelar em até 12x. CORRE antes que saia do ar.</small></p>
        <button class="accept-btn kirvano-payment-trigger" type="button">QUERO GARANTIR COM 100 REAIS DE DESCONTO.</button>
        <button class="decline kirvano-refuse-trigger" type="button">NÃO QUERO ESSA OFERTA</button>
      </div>
    </div>
  </main>
  <!-- Kirvano downsell (funil montado no Kirvano) -->
  <script is:inline>
    var offer = "d8ba95e1-dbe6-4dd4-9f86-f36ff0f6e517";
    var nextPageURL = "https://lp05.irmandadedodolar.com.br/priority-pass-2/";
    var refusePageURL = "https://lp05.irmandadedodolar.com.br/priority-pass-downsell/";
  </script>
  <script is:inline src="https://snippets.kirvano.com/upsell.min.js"></script>
  <!-- reveal timer: 1:30 após o play. Robusto a 2º plano (Date.now) + ?preview p/ QA. -->
  <script is:inline>
    (function () {
      var DELAY = 90 * 1000; // 1:30 = 90s
      var KEY = 'al_dn01_revealed', started = 0, iv = null;
      function reveal() { document.documentElement.classList.remove('gated'); try { localStorage.setItem(KEY, '1'); } catch (e) {} if (iv) { clearInterval(iv); iv = null; } }
      function check() { if (started && Date.now() - started >= DELAY) reveal(); }
      try { if (/[?&]preview/.test(location.search)) { document.documentElement.classList.remove('gated'); return; } } catch (e) {}
      try { if (localStorage.getItem(KEY)) { reveal(); return; } } catch (e) {}
      window.__startVslTimer = function () { if (started) return; started = Date.now(); setTimeout(reveal, DELAY); iv = setInterval(check, 1000); document.addEventListener('visibilitychange', check); window.addEventListener('focus', check); };
    })();
  </script>
</Funnel>
