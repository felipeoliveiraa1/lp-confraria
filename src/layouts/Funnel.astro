---
// Layout das páginas de funil (upsell/downsell). Mesmo design system + tracking
// da principal, porém enxuto: só pré-carrega o poster da VSL desta página.
import '../styles/global.css';
const { title = 'A Sociedade Trader', poster } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

<link rel="preconnect" href="https://www.googletagmanager.com" />
<!-- Google Tag Manager — DIFERIDO (dataLayer na hora; gtm.js no 1º gesto ou ~6s
     após o load) p/ manter a nota alta sem perder o PageView. -->
<script is:inline>
window.dataLayer=window.dataLayer||[];
(function(){var done=false;function load(){if(done)return;done=true;
  window.dataLayer.push({'gtm.start':new Date().getTime(),event:'gtm.js'});
  var g=document.createElement('script');g.async=true;g.src='https://www.googletagmanager.com/gtm.js?id=GTM-TXZ8KFR7';document.head.appendChild(g);
}
['scroll','touchstart','mousemove','pointerdown','keydown','click','wheel'].forEach(function(e){addEventListener(e,load,{once:true,passive:true})});
addEventListener('load',function(){setTimeout(load,6000)});
})();
</script>
<!-- End Google Tag Manager -->

<title>{title}</title>
<meta name="robots" content="noindex,nofollow" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<!-- vturb optimizer: marca o relógio do player o quanto antes -->
<script is:inline>!function(i,n){i._plt=i._plt||(n&&n.timeOrigin?n.timeOrigin+n.now():Date.now())}(window,performance);</script>

<!-- abre conexões cedo (VSL) -->
<link rel="preconnect" href="https://scripts.converteai.net" crossorigin />
<link rel="preconnect" href="https://cdn.converteai.net" crossorigin />
<link rel="preconnect" href="https://images.converteai.net" crossorigin />
<link rel="dns-prefetch" href="https://license.vturb.com" />
<!-- fonte da marca -->
<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-600.woff2" />
<link rel="preload" as="font" type="font/woff2" crossorigin href="/assets/InstrumentSans-500.woff2" />
{poster && <link rel="preload" as="image" href={poster} fetchpriority="high" />}
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TXZ8KFR7" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<slot />
<!-- countdown de escassez (roda só se houver #cd; para em 00:00) -->
<script is:inline>
  (function(){var el=document.getElementById('cd');if(!el)return;var t=15*60;
   (function tick(){var m=Math.floor(t/60),s=t%60;el.textContent=m+':'+(s<10?'0':'')+s;
    if(t>0){t--;setTimeout(tick,1000);}})();})();
</script>
</body>
</html>
